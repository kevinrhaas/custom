# ================================================================================================
# Local test-DB copy — configuration
# ================================================================================================
# Copy to db.env and adjust as needed:
#   cp db.env.template db.env
# Then (with the VPN connected) run:
#   ./copy-test-db.sh db.env
# ================================================================================================

# ------------------------------------------------------------------------------------------------
# Local Postgres (the destination — runs in Docker via docker-compose.yml)
# ------------------------------------------------------------------------------------------------
LOCAL_PG_IMAGE=postgres:17          # match the source major version (source is PG 17)
LOCAL_CONTAINER_NAME=test-db-local
LOCAL_PORT=5433                     # host port -> container 5432 (5433 avoids clashing with a local 5432)
LOCAL_SUPERUSER=postgres
LOCAL_PASSWORD=postgres
LOCAL_DEFAULT_DB=postgres

# ------------------------------------------------------------------------------------------------
# Source credentials come from the SE repo's pdc_analysis.properties (BIDB_* / BIDB_EXT_*).
# Point this at your local checkout of kevinrhaas/solution-engineering.
# ------------------------------------------------------------------------------------------------
PROPERTIES_FILE=../solution-engineering/pdc-analysis/content/public/pdc-analysis/utility/properties/pdc_analysis.properties

# ------------------------------------------------------------------------------------------------
# What to copy (decision: BOTH)
# ------------------------------------------------------------------------------------------------
# bidb — the underlying real-data DB (host 10.80.230.246, db bidb, user bidb_ro)
COPY_BIDB=yes
BIDB_TARGET_DB=bidb
BIDB_SCHEMAS=bidb

# bidb_ext — the RDS layer (airlinesample..., db postgres). These schemas use postgres_fdw;
# regular tables/materialized data copy fine, foreign tables need the FDW repointed (see README).
COPY_BIDB_EXT=yes
BIDB_EXT_TARGET_DB=bidb_ext
BIDB_EXT_SCHEMAS=bidb_ext_dev bidb_ext_demo bidb_ext_jcd

# Dump scope: "all" (schema + data) or "schema-only"
DUMP_SCOPE=all

# After copying, repoint the bidb_ext postgres_fdw server at the LOCAL bidb copy so foreign
# tables resolve offline (yes/no). Requires COPY_BIDB=yes.
REPOINT_FDW_TO_LOCAL=yes
